{
  "name": "Revenue Dashboard Light",
  "dataColors": [
    "#0F6CBD",
    "#107C10",
    "#C19C00",
    "#D83B01",
    "#5C2D91",
    "#008575",
    "#E3008C",
    "#68768A"
  ],
  "foreground": "#1F2328",
  "foregroundNeutralSecondary": "#57606A",
  "foregroundNeutralTertiary": "#8C959F",
  "background": "#FFFFFF",
  "backgroundLight": "#F6F8FA",
  "backgroundNeutral": "#D0D7DE",
  "tableAccent": "#0F6CBD",
  "good": "#107C10",
  "neutral": "#C19C00",
  "bad": "#D83B01",
  "textClasses": {
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 28,
      "color": "#1F2328"
    },
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 13,
      "color": "#1F2328"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#1F2328"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#57606A"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#D0D7DE"
              }
            },
            "radius": 4
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2328"
              }
            },
            "backgroundColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "alignment": "left"
          }
        ],
        "categoryAxis": [
          {
            "gridlineStyle": "dotted",
            "concatenateLabels": false
          }
        ],
        "valueAxis": [
          {
            "gridlineStyle": "dotted"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F6F8FA"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ]
      }
    },
    "cardVisual": {
      "*": {
        "label": [
          {
            "fontColor": {
              "solid": {
                "color": "#57606A"
              }
            }
          }
        ],
        "value": [
          {
            "fontColor": {
              "solid": {
                "color": "#0F6CBD"
              }
            },
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    }
  }
}
